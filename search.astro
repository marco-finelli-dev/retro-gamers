---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import { fetchAPI } from '../lib/api';

const query = Astro.url.searchParams.get('q') || '';

// 🔐 sanificazione base per GraphQL
const safeQuery = query.replace(/\\/g, '\\\\').replace(/"/g, '\\"');

let posts = [];

if (safeQuery) {
  const data = await fetchAPI(`
  {
    posts(where: { search: "${safeQuery}" }) {
      nodes {
        title
        slug
        excerpt
      }
    }
  }
  `);

  posts = data.posts.nodes;
}
---

<BaseLayout title={`Ricerca: ${query}`}>

<h1>Risultati per: {query}</h1>

{posts.length === 0 && <p>Nessun risultato</p>}

{posts.map(post => (
  <div>
    <a href={`/recensioni/${post.slug}`}>
      <h3>{post.title}</h3>
    </a>
    <div innerHTML={post.excerpt} />
  </div>
))}

</BaseLayout>