---
import Layout from '../../layouts/BaseLayout.astro';
import ArticlePage from '../../components/article/ArticlePage.astro';

import { client } from '../../lib/sanity';
import { getAllPosts, groupPosts } from '../../lib/posts';

const { category, slug } = Astro.params;

const categoryToType = {
  recensioni: 'review',
  news: 'news',
  speciali: 'feature',
  guide: 'guide',
  memories: 'memories',
  interviste: 'interview',
  hardware: 'hardware',
  articoli: 'article'
};

const expectedType = categoryToType[category];

if (!expectedType) {
  return Astro.redirect('/');
}

/* ========================
   READING TIME
======================== */

function getPlainTextFromContent(content = []) {
  return content
    .flatMap((block) => {
      if (block._type === 'block') {
        return block.children?.map((child) => child.text || '') || [];
      }

      if (block._type === 'asideBox') {
        return block.content
          ?.filter((inner) => inner._type === 'block')
          .flatMap((inner) =>
            inner.children?.map((child) => child.text || '') || []
          ) || [];
      }

      return [];
    })
    .join(' ');
}

function getReadingTime(content = []) {
  const text = getPlainTextFromContent(content);
  const words = text.trim().split(/\s+/).filter(Boolean).length;

  return Math.max(1, Math.ceil(words / 220));
}

const post = await client.fetch(`
*[
  _type == "article" &&
  slug.current == $slug &&
  type == $expectedType
][0]{
  _id,
  _type,
  type,

  title,
  subtitle,
  excerpt,
  seoTitle,

  "slug": slug.current,
  publishedAt,
  viewsBase,

  author->{
    name,
    "slug": slug.current
  },

  featuredImage {
    alt,
    asset->{ url }
  },

  categories[]->{
    name,
    "slug": slug.current
  },

  platforms[]->{
    name,
    "slug": slug.current
  },

  genres[]->{
    name,
    "slug": slug.current
  },

  developers[]->{
    name,
    "slug": slug.current
  },

  publishers[]->{
    name,
    "slug": slug.current
  },

  manufacturer[]->{
    name,
    "slug": slug.current
  },

  modes[]->{
    name,
    "slug": slug.current
  },

  series[]->{
    name,
    "slug": slug.current
  },

  editorialSeries[]->{
    name,
    "slug": slug.current
  },

  relatedSeries[]->{
    name,
    "slug": slug.current
  },

  gameInfo {
    releaseYear,
    mediaFormat,
    cover {
      alt,
      asset->{ url }
    }
  },

  rating,

  content[]{
    ...,

    markDefs[]{
      ...,

      _type == "internalLink" => {
        ...,
        reference->{
          type,
          "slug": slug.current
        }
      },

      _type == "taxonomyLink" => {
        ...,
        reference->{
          "slug": slug.current
        }
      }
    },

    _type == "image" => {
      ...,
      asset->{ url }
    },

    _type == "imageRow" => {
      ...,
      images[]{
        ...,
        image{
          asset->{ url }
        }
      }
    },

    _type == "asideBox" => {
      ...,
      content[]{
        ...,

        markDefs[]{
          ...,

          _type == "internalLink" => {
            ...,
            reference->{
              type,
              "slug": slug.current
            }
          },

          _type == "taxonomyLink" => {
            ...,
            reference->{
              "slug": slug.current
            }
          }
        },

        _type == "image" => {
          ...,
          asset->{ url }
        }
      }
    },

    _type == "video" => {
      url
    }
  }
}
`, {
  slug,
  expectedType
});

if (!post) {
  return Astro.redirect('/');
}

const readingTime = getReadingTime(post.content);

const hydratedPost = {
  ...post,
  readingTime
};

const allPosts = await getAllPosts();
const { reviews, news } = groupPosts(allPosts);
---

<Layout reviews={reviews} news={news}>
  <ArticlePage post={hydratedPost} />
</Layout>