---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PlatformsLanding from '../../components/platforms/PlatformsLanding.astro';

import { getAllPosts, groupPosts } from '../../lib/posts';
import { getAllPlatforms } from '../../lib/platforms';

const allPosts = await getAllPosts();
const grouped = groupPosts(allPosts);

const platforms = await getAllPlatforms();
---

<BaseLayout reviews={grouped.allReviews} news={grouped.allNews}>
  <PlatformsLanding platforms={platforms} />
</BaseLayout>