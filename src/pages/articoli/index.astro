---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArchivePage from '../../components/archive/ArchivePage.astro';

import { getAllPosts, groupPosts } from '../../lib/posts';

const allPosts = await getAllPosts();
const grouped = groupPosts(allPosts);

const posts = grouped.all.filter((post) => post.type === 'article');
---

<BaseLayout reviews={grouped.allReviews} news={grouped.allNews}>
  <ArchivePage
    title="Articoli"
    eyebrow="Archivio editoriale"
    description="Articoli generali, riflessioni e contenuti che non rientrano nelle sezioni principali."
    posts={posts}
    showFilters={false}
  />
</BaseLayout>