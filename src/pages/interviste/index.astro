---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArchivePage from '../../components/archive/ArchivePage.astro';

import { getAllPosts, groupPosts } from '../../lib/posts';

const allPosts = await getAllPosts();
const grouped = groupPosts(allPosts);

const posts = grouped.all.filter((post) => post.type === 'interview');
---

<BaseLayout reviews={grouped.allReviews} news={grouped.allNews}>
  <ArchivePage
    title="Interviste"
    eyebrow="Voci e protagonisti"
    description="Conversazioni con autori, sviluppatori, appassionati e protagonisti della scena retro."
    posts={posts}
    showFilters={false}
  />
</BaseLayout>