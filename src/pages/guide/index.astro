---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArchivePage from '../../components/archive/ArchivePage.astro';

import { getAllPosts, groupPosts } from '../../lib/posts';

const allPosts = await getAllPosts();
const grouped = groupPosts(allPosts);

const posts = grouped.all.filter((post) => post.type === 'guide');
---

<BaseLayout reviews={grouped.allReviews} news={grouped.allNews}>
  <ArchivePage
    title="Guide"
    eyebrow="Manuali e percorsi"
    description="Guide pratiche, consigli, procedure e approfondimenti per vivere meglio il retro-gaming."
    posts={posts}
    showFilters={false}
  />
</BaseLayout>