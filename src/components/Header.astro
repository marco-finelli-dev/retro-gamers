---
import PlatformsMenu from './header/PlatformsMenu.astro';
import ReviewsMenu from './header/ReviewsMenu.astro';
import NewsMenu from './header/NewsMenu.astro';
import Search from './header/Search.astro';
import { getArchiveUrl } from '../lib/routes';

// 👉 ricevi dati dal layout
const { reviews = [], news = [] } = Astro.props;
---

<header class="header">
  <div class="header__container">

    <!-- LOGO -->
    <a href="/" class="header__logo" aria-label="Homepage Retro Gamers">
      <img
        src="/retro-gamer-header-logo.webp"
        class="header__logo-text"
        alt="Retro Gamers"
        loading="eager"
      />
    </a>

    <!-- NAV -->
    <nav class="header__nav" aria-label="Navigazione principale">

      <!-- PIATTAFORME -->
      <div class="nav-item has-dropdown">
        <button class="nav-link" aria-haspopup="true" aria-expanded="false">
          <span class="nav-icon">☰</span>
          <span>Piattaforme</span>
        </button>
        <PlatformsMenu />
      </div>

      <!-- RECENSIONI -->
      <div class="nav-item has-dropdown">
        <button class="nav-link" aria-haspopup="true" aria-expanded="false">
          <span class="nav-icon">☰</span>
          <span>Recensioni</span>
        </button>

        {/* 🔥 ORA PASSI I DATI */}
        <ReviewsMenu posts={reviews} />
      </div>

      <!-- NEWS -->
      <div class="nav-item has-dropdown">
        <button class="nav-link" aria-haspopup="true" aria-expanded="false">
          <span class="nav-icon">☰</span>
          <span>News</span>
        </button>
      <NewsMenu posts={news} />
      </div>

      <!-- LINK DIRETTI -->
       <a href={getArchiveUrl('feature')} class="nav-link">Speciali</a>
       <a href={getArchiveUrl('guide')} class="nav-link">Guide</a>
       <a href={getArchiveUrl('interview')} class="nav-link">Interviste</a>
       <a href={getArchiveUrl('memories')} class="nav-link">Memories</a>

    </nav>

    <!-- SEARCH -->
    <div class="header__right">
      <Search />
    </div>

  </div>
</header>