---
import '../../styles/components/header/search.css';
---

<div class="search-wrapper">

  <div class="search-toggle">
    <svg viewBox="0 0 24 24">
      <circle cx="11" cy="11" r="7" stroke="white" stroke-width="2" fill="none"/>
      <line x1="16" y1="16" x2="21" y2="21" stroke="white" stroke-width="2"/>
    </svg>
  </div>

  <div class="search-bar">
    <input type="text" placeholder="Cerca nel sito..." />

    <div class="search-results">
      <div class="hover-bg"></div>
    </div>

    <div class="search-close">✕</div>
  </div>

</div>

<div class="search-overlay"></div>

<script is:inline>
(() => {

  /* ========================
     HELPERS
  ======================== */

  function normalize(str = '') {
    return str
      .toLowerCase()
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '');
  }

  function scoreItem(item, query) {
    const q = normalize(query);

    const title = normalize(item.title || '');
    const extra = normalize(item.searchableText || '');

    if (title === q) return 100;
    if (title.startsWith(q)) return 90;
    if (title.includes(q)) return 75;
    if (extra.includes(q)) return 50;

    return 0;
  }

  function escapeHTML(str = '') {
    return str.replace(/[&<>"']/g, m => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#39;'
    }[m]));
  }

  function highlight(text, query) {
    const safe = escapeHTML(text);
    const q = query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    return safe.replace(new RegExp(`(${q})`, 'gi'),
      '<span class="highlight">$1</span>'
    );
  }

  /* ========================
     ELEMENTI
  ======================== */

  const wrapper = document.querySelector('.search-wrapper');
  if (!wrapper) return;

  const toggle = wrapper.querySelector('.search-toggle');
  const bar = wrapper.querySelector('.search-bar');
  const closeBtn = wrapper.querySelector('.search-close');
  const input = wrapper.querySelector('input');
  const results = wrapper.querySelector('.search-results');
  const overlay = document.querySelector('.search-overlay');

  let debounce;
  let cache = null;

  /* ========================
     UI CONTROL
  ======================== */

  function reset() {
    results.classList.remove('active');
    results.innerHTML = '<div class="hover-bg"></div>';
  }

function open() {
  if (document.body.classList.contains('no-scroll')) return;

  const scrollbarWidth = window.innerWidth - document.documentElement.clientWidth;

  document.body.style.setProperty('--scrollbar-width', `${scrollbarWidth}px`);
  document.body.classList.add('no-scroll');

  bar.classList.add('active');
  overlay?.classList.add('active');

  input.focus();
}

function close() {
  if (!document.body.classList.contains('no-scroll')) return;

  bar.classList.remove('active');
  overlay?.classList.remove('active');

  document.body.classList.remove('no-scroll');
  document.body.style.removeProperty('--scrollbar-width');

  input.value = '';
  reset();
}

  toggle?.addEventListener('click', e => {
    e.stopPropagation();
    open();
  });

  closeBtn?.addEventListener('click', close);
  overlay?.addEventListener('click', close);

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') close();
  });

  document.addEventListener('click', e => {
    if (!wrapper.contains(e.target)) close();
  });

  /* ========================
     SEARCH
  ======================== */

  input?.addEventListener('input', () => {

    const query = input.value.trim();
    clearTimeout(debounce);

    if (query.length < 2) {
      reset();
      return;
    }

    debounce = setTimeout(async () => {

      try {

        if (!cache) {
          const res = await fetch('/api/search');
          cache = await res.json();
        }

        /* ========================
           BUILD INDEX
        ======================== */

       const articleLabels = {
  review: 'Recensione',
  article: 'Articolo',
  guide: 'Guida',
  interview: 'Intervista',
  news: 'News',
  feature: 'Speciale',
  memories: 'Memories'
};

const taxonomyLabels = {
  genre: 'Genere',
  developer: 'Sviluppatore',
  publisher: 'Publisher',
  manufacturer: 'Produttore',
  mode: 'Modalità',
  series: 'Serie',
  editorialSeries: 'Serie editoriale'
};

const platformLabels = {
  console: 'Console',
  computer: 'Computer',
  arcade: 'Arcade'
};

const getTaxonomyType = (taxonomy) => {
  const types = taxonomy.type || [];
  return Array.isArray(types) ? types[0] : types;
};

const all = [

  ...cache.articles.map(a => ({
    ...a,
    kind: 'article',
    label: articleLabels[a.type] || 'Articolo',
    url: `/articoli/${a.slug}/`,
    image: a.featuredImage?.asset?.url || '',
    eyebrow: [
      articleLabels[a.type] || 'Articolo',
      a.platforms?.[0]?.name,
      a.gameInfo?.releaseYear
    ].filter(Boolean).join(' · '),
    searchableText: `
      ${a.title || ''}
      ${a.excerpt || ''}
      ${a.type || ''}
      ${(a.categories || []).map(c => c.name).join(' ')}
      ${(a.platforms || []).map(p => p.name).join(' ')}
      ${(a.genres || []).map(g => g.name).join(' ')}
      ${(a.developers || []).map(d => d.name).join(' ')}
      ${a.gameInfo?.releaseYear || ''}
    `
  })),

  ...cache.platforms.map(p => ({
    title: p.name,
    slug: p.slug,
    kind: 'platform',
    label: platformLabels[p.platformType] || 'Piattaforma',
    url: `/piattaforme/${p.slug}/`,
    image: p.cover?.asset?.url || '',
    eyebrow: [
      platformLabels[p.platformType] || 'Piattaforma',
      p.manufacturer?.name,
      p.specs?.year
    ].filter(Boolean).join(' · '),
    searchableText: `
      ${p.name || ''}
      ${p.platformType || ''}
      ${p.manufacturer?.name || ''}
      ${p.specs?.year || ''}
    `
  })),

  ...cache.taxonomies.map(t => {
    const taxonomyType = getTaxonomyType(t);

    return {
      title: t.name,
      slug: t.slug,
      kind: 'taxonomy',
      label: taxonomyLabels[taxonomyType] || 'Archivio',
      url: `/tassonomie/${t.slug}/`,
      image: t.logo?.asset?.url || '',
      eyebrow: taxonomyLabels[taxonomyType] || 'Archivio',
      searchableText: `
        ${t.name || ''}
        ${taxonomyType || ''}
      `
    };
  })
];

        /* ========================
           RANKING
        ======================== */

        const ranked = all
          .map(item => ({
            ...item,
            score: scoreItem(item, query)
          }))
          .filter(i => i.score > 0)
          .sort((a, b) => b.score - a.score)
          .slice(0, 6);

        /* ========================
           RENDER
        ======================== */

        let html = '<div class="hover-bg"></div>';

        if (!ranked.length) {
          html += `
  <div class="search-empty">
    <strong>Nessun risultato</strong>
    <span>Prova con un gioco, una piattaforma, un genere o uno sviluppatore.</span>
  </div>
`;
        } else {

         html += ranked.map(post => {

  const image = post.image || '';
  const title = post.title || '';
  const eyebrow = post.eyebrow || post.label || '';

  return `
    <a href="${post.url}" class="search-item">

      <div class="search-thumb ${image ? '' : 'is-empty'}">
        ${image ? `<img src="${image}" alt="">` : `<span>${escapeHTML(post.label?.slice(0, 2) || 'RG')}</span>`}
      </div>

      <div class="search-content">
        <div class="search-category">
          ${escapeHTML(eyebrow)}
        </div>

        <div class="search-title">
          ${highlight(title, query)}
        </div>
      </div>

    </a>
  `;
}).join('');
        }

        results.innerHTML = html;
        results.classList.add('active');

      } catch (err) {
        console.error('Search error:', err);
        reset();
      }

    }, 200);
  });

})();

window.addEventListener('load', () => {
  document.body.classList.remove('no-scroll');
  document.body.style.removeProperty('--scrollbar-width');
});
</script>