---
import '../../styles/components/header/dropdown.css';
import { getPostUrl } from '../../lib/routes';
const { posts = [] } = Astro.props;
---
<div class="dropdown-wrapper">
<div class="dropdown-menu">

  {posts.slice(0, 5).map((p) => {

    const image = p.featuredImage?.asset?.url;
    const category = p.categories?.[0]?.name || '';

    return (
      <a href={getPostUrl(p)} class="dropdown-item">

        <div class="dropdown-thumb">
          {image && (
            <img src={image} alt={p.title || ''} />
          )}
        </div>

        <div class="dropdown-content">

          <div class="dropdown-meta">
            {category}
          </div>

          <div class="dropdown-title">
            {p.title}
          </div>

        </div>

      </a>
    );
  })}

  <a href="/news/" class="dropdown-more">
    Vedi tutte le news →
  </a>

</div>
</div>