---
import '../../styles/components/header/dropdown.css';
import { getPostUrl } from '../../lib/routes';
const { posts = [] } = Astro.props;

// =========================
// LOGICA
// =========================

const all = posts
  .map(p => ({
    ...p,
    score: p?.score ?? 0
  }))
  .sort((a, b) => {
    if (b.score === a.score) {
      return new Date(b.publishedAt) - new Date(a.publishedAt);
    }
    return b.score - a.score;
  });

const topAll = all.filter(p => p.score >= 9.5);
const mustAll = all.filter(p => p.score >= 9 && p.score < 9.5);
const goodAll = all.filter(p => p.score >= 8.5 && p.score < 9);

let top = topAll.slice(0, 2);
let must = mustAll.slice(0, 2);
let good = goodAll.slice(0, 1);

if (must.length < 2) {
  const missing = 2 - must.length;

  const extraTop = topAll.slice(2, 2 + Math.ceil(missing / 2));
  const extraGood = goodAll.slice(1, 1 + Math.floor(missing / 2));

  top = [...top, ...extraTop];
  good = [...good, ...extraGood];
}

const finalPosts = [...top, ...must, ...good].slice(0, 5);
---
<div class="dropdown-wrapper">
<div class="dropdown-menu">

  {finalPosts.map((post) => {

    const score = post.score ?? 0;
    const formattedScore = Number(score).toFixed(1);

    const platformName = post.platforms?.[0]?.name || '';
    const developer = post.developers?.[0]?.name || '';
    const year = post.gameInfo?.releaseYear || '';

    const image = post.featuredImage?.asset?.url;

    return (
      <a href={getPostUrl(post)} class="dropdown-item">

        {/* IMAGE */}
        <div class="dropdown-thumb">
          {image && (
            <img src={image} alt={post.title || ''} />
          )}
        </div>

        {/* CONTENT */}
        <div class="dropdown-content">

          <div class="dropdown-meta">
            {platformName}
            {developer && ` · ${developer}`}
            {year && ` · ${year}`}
          </div>

          <div class="dropdown-title">
            {post.title}
          </div>

        </div>

        {/* SCORE */}
        <div class={`reviews-score ${
          score >= 9 ? 'is-top' :
          score >= 7 ? 'is-mid' :
          'is-low'
        }`}>

          <span class="reviews-score-value">{formattedScore}</span>

          {score >= 9.5 && <span class="reviews-badge gold">TOP</span>}
          {score >= 9 && score < 9.5 && <span class="reviews-badge silver">MUST</span>}
          {score >= 8.5 && score < 9 && <span class="reviews-badge bronze">GOOD</span>}

        </div>

      </a>
    );
  })}

  <a href="/recensioni/" class="dropdown-more">
    Vedi tutte le recensioni →
  </a>

</div>
</div>