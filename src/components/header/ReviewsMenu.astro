---
import '../../styles/components/header/dropdown.css';
import { getPostUrl } from '../../lib/routes';

const { posts = [] } = Astro.props;

/* =========================
   DATA
========================= */

const all = posts
  .map((p) => ({
    ...p,
    score: p?.score ?? p?.rating?.overall ?? 0
  }))
  .sort((a, b) => {
    if (b.score === a.score) {
      return new Date(b.publishedAt || 0) - new Date(a.publishedAt || 0);
    }

    return b.score - a.score;
  });

const finalPosts = all.slice(0, 5);

const formatScore = (score) =>
  score ? Number(score).toFixed(1) : '-';

const getScoreLabel = (score) => {
  if (score >= 9.5) return 'TOP';
  if (score >= 9) return 'MUST';
  if (score >= 8.5) return 'GOOD';
  return '';
};

const getScoreClass = (score) => {
  if (score >= 9.5) return 'is-top';
  if (score >= 9) return 'is-must';
  if (score >= 8.5) return 'is-good';
  return 'is-low';
};

const getMeta = (post) => {
  const platform = post.platforms?.[0]?.name || '';
  const developer = post.developers?.[0]?.name || '';
  const year = post.gameInfo?.releaseYear || '';

  return [platform, developer, year].filter(Boolean).join(' · ');
};
---

<div class="rg-dropdown rg-dropdown--reviews">

  <div class="rg-dropdown__panel">

    {finalPosts.map((post) => {
      const image = post.featuredImage?.asset?.url;
      const score = post.score ?? 0;

      return (
        <a href={getPostUrl(post)} class="rg-dropdown__item rg-dropdown__item--review">

          <div class="rg-dropdown__thumb">
            {image && (
              <img src={image} alt={post.title || ''} loading="lazy" />
            )}
          </div>

          <div class="rg-dropdown__content">

            {getMeta(post) && (
              <div class="rg-dropdown__meta">
                {getMeta(post)}
              </div>
            )}

            <div class="rg-dropdown__title">
              {post.title}
            </div>

          </div>

          <div class={`rg-dropdown__score ${getScoreClass(score)}`}>
            <span>{formatScore(score)}</span>
            {getScoreLabel(score) && (
              <small>{getScoreLabel(score)}</small>
            )}
          </div>

        </a>
      );
    })}

    <a href="/recensioni/" class="rg-dropdown__more">
      Vedi tutte le recensioni <span>→</span>
    </a>

  </div>

</div>