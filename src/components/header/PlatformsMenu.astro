---
import { fetchAPI } from '../../lib/api';
import '../../styles/components/header/platforms.css';

let terms = [];

try {
  const data = await fetchAPI(`
  {
    platforms(first: 100) {
      nodes {
        id
        name
        slug
        parentId
        specifichePiattaforma {
          logoMenu {
            node {
              sourceUrl
            }
          }
        }
      }
    }
  }
  `);

  terms = data?.platforms?.nodes || [];
} catch (e) {
  console.error('PlatformsMenu fetch error', e);
}

/* ========================
   TREE BUILD
======================== */

const map = {};
terms.forEach(t => {
  map[t.id] = { ...t, children: [] };
});

const tree = [];
terms.forEach(t => {
  if (!t.parentId) {
    tree.push(map[t.id]);
  } else if (map[t.parentId]) {
    map[t.parentId].children.push(map[t.id]);
  }
});

const safeTree = [...tree];

/* ========================
   HELPERS
======================== */

const darkLogos = ['sega', 'commodore', 'nec', 'sony', 'snk'];

const isDarkLogo = (name = '') =>
  darkLogos.some(n => name.toLowerCase().includes(n));

/* ========================
   SORT "ALTRI"
======================== */

const altriIndex = safeTree.findIndex(t =>
  t?.slug === 'altri-sistemi' ||
  t?.name?.toLowerCase().includes('altri')
);

if (altriIndex !== -1) {
  const [altri] = safeTree.splice(altriIndex, 1);
  safeTree.push(altri);
}
---

<div class="mega platforms-mega">

  <div class="mega-menu">

    <!-- COLONNA 1 -->
    <div class="col col-1">
      <div class="hover-bg"></div>
      <div class="active-bar"></div>

      {safeTree.map((p, i) => (
        <div class="item" data-id={`p-${i}`}>

          <div class={`menu-icon ${isDarkLogo(p.name) ? 'light-bg' : ''}`}>
            {p?.specifichePiattaforma?.logoMenu?.node?.sourceUrl && (
              <img
                src={p.specifichePiattaforma.logoMenu.node.sourceUrl}
                alt={p.name}
              />
            )}
          </div>

          <span>{p.name}</span>

        </div>
      ))}
    </div>

    <!-- COLONNA 2 -->
    <div class="col col-2">
      <div class="hover-bg"></div>
      <div class="active-bar"></div>

      {safeTree.map((p, i) => (
        <div class="panel level-2" data-parent={`p-${i}`}>

          {(p.children || []).map((child, j) => (
            child.children?.length > 0 ? (

              <div class="subitem" data-id={`p-${i}-c-${j}`}>

                <div class={`menu-icon ${isDarkLogo(child.name) ? 'light-bg' : ''}`}>
                  {child?.specifichePiattaforma?.logoMenu?.node?.sourceUrl && (
                    <img
                      src={child.specifichePiattaforma.logoMenu.node.sourceUrl}
                      alt={child.name}
                    />
                  )}
                </div>

                <span>{child.name}</span>

              </div>

            ) : (

              <a
                href={`/piattaforme/${child.slug}/`}
                class="subitem no-children"
                data-id={`p-${i}-c-${j}`}
              >

                <div class={`menu-icon ${isDarkLogo(child.name) ? 'light-bg' : ''}`}>
                  {child?.specifichePiattaforma?.logoMenu?.node?.sourceUrl && (
                    <img
                      src={child.specifichePiattaforma.logoMenu.node.sourceUrl}
                      alt={child.name}
                    />
                  )}
                </div>

                <span>{child.name}</span>

              </a>

            )
          ))}

        </div>
      ))}
    </div>

    <!-- COLONNA 3 -->
    <div class="col col-3">
      <div class="hover-bg"></div>

      {safeTree.map((p, i) =>
        (p.children || []).map((child, j) =>
          child.children?.length > 0 && (
            <div class="panel level-3" data-parent={`p-${i}-c-${j}`}>

              {child.children.map((sub) => (
                <a
                  href={`/piattaforme/${sub.slug}/`}
                  class="submenu-link"
                >

                  <div class={`menu-icon ${isDarkLogo(sub.name) ? 'light-bg' : ''}`}>
                    {sub?.specifichePiattaforma?.logoMenu?.node?.sourceUrl && (
                      <img
                        src={sub.specifichePiattaforma.logoMenu.node.sourceUrl}
                        alt={sub.name}
                      />
                    )}
                  </div>

                  <span>{sub.name}</span>

                </a>
              ))}

            </div>
          )
        )
      )}
    </div>

  </div>
</div>