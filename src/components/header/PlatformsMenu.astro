---
import '../../styles/components/header/dropdown.css';

const items = [
  {
    title: 'Console',
    label: 'Sistemi da salotto',
    href: '/piattaforme/console/',
    code: 'TV'
  },
  {
    title: 'Computer',
    label: 'Home computer',
    href: '/piattaforme/computer/',
    code: 'PC'
  },
  {
    title: 'Arcade',
    label: 'Cabinet e board',
    href: '/piattaforme/arcade/',
    code: 'AR'
  }
];
---

<div class="rg-dropdown rg-dropdown--platforms">

  <div class="rg-dropdown__panel rg-dropdown__panel--platforms">

    <div class="rg-platforms-grid">

      {items.map((item) => (
        <a href={item.href} class="rg-platform-link">

          <span class="rg-platform-link__icon">
            {item.code}
          </span>

          <span class="rg-platform-link__text">
            <strong>{item.title}</strong>
            <small>{item.label}</small>
          </span>

        </a>
      ))}

    </div>

    <a href="/piattaforme/" class="rg-dropdown__more">
      Tutte le piattaforme <span>→</span>
    </a>

  </div>

</div>