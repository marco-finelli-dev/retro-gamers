---
import '../styles/components/footer.css';

const currentYear = new Date().getFullYear();
---

<footer class="site-footer">

  <div class="container">

    <div class="site-footer__inner">

      <!-- BRAND -->
      <div class="site-footer__brand">

        <a href="/" class="site-footer__logo" aria-label="Retro Gamers home">
          <img src="/images/retro-gamer-header-logo.webp" alt="Retro Gamers" />
        </a>

        <p>
          Tutta la magia di un’epoca che ha segnato le nostre vite da adolescenti.
        </p>

        <strong>
          Retro-Gamers.it, il sito che vi riporterà nel passato!
        </strong>

        <div class="site-footer__socials" aria-label="Social Retro-Gamers">

          <a href="https://www.facebook.com/" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
            FB
          </a>

          <a href="https://www.instagram.com/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            IG
          </a>

          <a href="https://x.com/" target="_blank" rel="noopener noreferrer" aria-label="X">
            X
          </a>

          <a href="mailto:info@retro-gamers.it" aria-label="Email">
            @
          </a>

        </div>

      </div>


      <!-- SCOPRI -->
      <nav class="site-footer__nav" aria-label="Scopri">
        <h2>Scopri</h2>

        <a href="/recensioni/">Recensioni</a>
        <a href="/news/">News</a>
        <a href="/speciali/">Speciali</a>
        <a href="/guide/">Guide</a>
        <a href="/memories/">Memories</a>
        <a href="/interviste/">Interviste</a>
      </nav>


      <!-- PIATTAFORME -->
      <nav class="site-footer__nav" aria-label="Piattaforme">
        <h2>Piattaforme</h2>

        <a href="/piattaforme/console/">Console</a>
        <a href="/piattaforme/computer/">Computer</a>
        <a href="/piattaforme/arcade/">Arcade</a>
        <a href="/piattaforme/">Tutte le piattaforme</a>
      </nav>


      <!-- INFO -->
      <nav class="site-footer__nav" aria-label="Info">
        <h2>Info</h2>

        <a href="/chi-siamo/">Chi siamo</a>
        <a href="/collaborazioni/">Collaborazioni</a>
        <a href="/contatti/">Contatti</a>
        <a href="/privacy-policy/">Privacy Policy</a>
      </nav>

    </div>


    <div class="site-footer__bottom">

      <p>
        © {currentYear} Retro-Gamers.it. Tutti i diritti riservati.
      </p>

      <p>
        Website by <strong>Marco Finelli</strong>
      </p>

    </div>

  </div>

</footer>