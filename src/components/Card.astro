---
const { post = null, showMeta = false } = Astro.props;

if (!post) return;

/* ========================
   DATA
======================== */

const title = post.title || '';
const slug = post.slug || '';
const image = post.featuredImage?.asset?.url || '/placeholder-retro.png';

/* ========================
   CATEGORY
======================== */

const category = post.categories?.[0] || null;
const categoryName = category?.name || '';
const categorySlug = category?.slug || '';

/* ========================
   META
======================== */

const piattaforme = post.platforms?.map(p => p.name).join(', ');
const sviluppatori = post.developers?.map(d => d.name).join(', ');
const anno = post.gameInfo?.releaseYear;

/* ========================
   EXCERPT
======================== */

const excerpt = post.excerpt || '';
---

<div class="card">

  <!-- IMAGE -->
  <a href={`/articoli/${slug}/`} class="card__image">
    <div class="screen">
      <img
        class="game"
        src={image}
        alt={title}
        loading="lazy"
      />
    </div>
  </a>

  <!-- CATEGORY -->
  {!showMeta && categoryName && (
    <div class="card__category">
      {categoryName}
    </div>
  )}

  <!-- META -->
  {showMeta && (
    <div class="meta">

      {piattaforme && (
        <span>{piattaforme}</span>
      )}

      {sviluppatori && (
        <>
          {" • "}
          <span>{sviluppatori}</span>
        </>
      )}

      {anno && (
        <>
          {" • "}
          <span>{anno}</span>
        </>
      )}

    </div>
  )}

  <!-- TITLE -->
  <h2 class="card__title">
    <a href={`/articoli/${slug}/`}>
      {title}
    </a>
  </h2>

  <!-- EXCERPT -->
  {excerpt && (
    <p class="excerpt">{excerpt}</p>
  )}

</div>