---
import '../../styles/components/hero.css';
import { getPostUrl } from '../../lib/routes';

const { posts = [] } = Astro.props;

const [main, ...rest] = posts || [];
const side = rest.slice(0, 3);

const getExcerpt = (post) =>
  post?.excerpt?.replace(/\[…\]/g, '').trim() || '';

const getCategory = (post) => {
  const cat = post?.categories?.[0];
  return cat ? cat.name : '';
};

const getTypeLabel = (type) => {
  const map = {
    review: 'Recensione',
    article: 'Articolo',
    guide: 'Guida',
    interview: 'Intervista',
    news: 'News',
    feature: 'Speciale',
    memories: 'Memories'
  };

  return map[type] || type || 'Articolo';
};
---

<div class="section-box rg-hero">

  <div class="rg-hero__ambient" aria-hidden="true"></div>

<div class="rg-hero__top">
  <div class="rg-hero__signal">
    <span>In evidenza</span>
    <strong>Retro-Gamers Magazine</strong>
  </div>

  <p>
    Arcade, console, home computer e memorie digitali.
  </p>
</div>

  <div class="rg-hero__grid">

    {main && (
      <a href={getPostUrl(main)} class="rg-hero-main">

        {main.featuredImage?.asset?.url && (
          <img
            src={main.featuredImage.asset.url}
            alt={main.featuredImage?.alt || main.title}
            loading="eager"
          />
        )}

        <div class="rg-hero-main__chrome" aria-hidden="true"></div>

        <div class="rg-hero-main__content">

          <div class="rg-hero__meta">
            <span>{getTypeLabel(main.type)}</span>

            {getCategory(main) && (
              <small>{getCategory(main)}</small>
            )}
          </div>

          <h2>{main.title}</h2>

          {getExcerpt(main) && (
            <p>{getExcerpt(main)}</p>
          )}

          <span class="rg-hero__cta">
            Leggi l’articolo
          </span>

        </div>

      </a>
    )}

    <div class="rg-hero-side-list">
      {side.map((post) => {
        const cat = getCategory(post);

        return (
          <a href={getPostUrl(post)} class="rg-hero-side-card">

            {post.featuredImage?.asset?.url && (
              <img
                src={post.featuredImage.asset.url}
                alt={post.featuredImage?.alt || post.title}
                loading="lazy"
              />
            )}

            <div class="rg-hero-side-card__content">

              <div class="rg-hero__meta small">
                <span>{getTypeLabel(post.type)}</span>

                {cat && (
                  <small>{cat}</small>
                )}
              </div>

              <h3>{post.title}</h3>

            </div>

          </a>
        );
      })}
    </div>

  </div>

</div>