---
import '../../styles/components/hero.css';

const { posts = [] } = Astro.props;

// SPLIT
const [main, ...rest] = posts || [];
const side = rest.slice(0, 3);

// HELPERS

const getExcerpt = (post) =>
  post?.excerpt || '';

const getCategory = (post) => {
  const cat = post?.categories?.[0];
  return cat
    ? { label: cat.name, href: `/${cat.slug}` }
    : null;
};

const getTypeLabel = (type) => {
  const map = {
    review: 'Recensione',
    article: 'Articolo',
    guide: 'Guida',
    interview: 'Intervista',
    news: 'News',
    feature: 'Speciale',
    memories: 'Memories'
  };

  return map[type] || type;
};
---

<section class="home-hero">
  <div class="container">
    <div class="section-box hero">

      <div class="hero-grid">

        {/* MAIN */}
        {main && (
          <div class="hero-main card" data-link={`/${main.slug}`}>

            {main.featuredImage?.asset?.url && (
              <img
                src={main.featuredImage.asset.url}
                alt={main.title}
              />
            )}

            <div class="card-content">

              <span class={`card-type ${main.type}`}>
                {getTypeLabel(main.type)}
              </span>

              {getCategory(main) && (
                <a href={getCategory(main).href} class="card-meta">
                  {getCategory(main).label}
                </a>
              )}

              <h1 class="card-title-xl">{main.title}</h1>

              {getExcerpt(main) && (
                <p class="card-excerpt">
                  {getExcerpt(main)}
                </p>
              )}

            </div>

          </div>
        )}

        {/* SIDE */}
        <div class="hero-right">
          {side.map((p) => {
            const cat = getCategory(p);

            return (
              <div class="hero-side card" data-link={`/${p.slug}`}>

                {p.featuredImage?.asset?.url && (
                  <img
                    src={p.featuredImage.asset.url}
                    alt={p.title}
                  />
                )}

                <div class="card-content small">

                  <span class={`card-type small ${p.type}`}>
                    {getTypeLabel(p.type)}
                  </span>

                  {cat && (
                    <a href={cat.href} class="card-meta small">
                      {cat.label}
                    </a>
                  )}

                  <h3 class="card-title-md">{p.title}</h3>

                </div>

              </div>
            );
          })}
        </div>

      </div>

    </div>
  </div>
</section>