---
import '../../styles/components/meta.css';
import '../../styles/components/hardware.css';

const hardware = (Astro.props.posts ?? []).slice(0, 4);
---

<div class="section-box hardware">

  <div class="section-header">
    <h2>Hardware</h2>
  </div>

  <div class="hardware-track">

    {hardware.map((post) => (
      <div class="hardware-item">

        <a href={`/articoli/${post.slug}/`} class="hardware-card">

          {post.featuredImage?.asset?.url && (
            <img
              src={post.featuredImage.asset.url}
              alt={post.title || ''}
              loading="lazy"
            />
          )}

        </a>

        <div class="hardware-content">
          <h3>{post.title}</h3>
        </div>

      </div>
    ))}

  </div>

</div>