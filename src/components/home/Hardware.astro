---
import '../../styles/components/hardware.css';
import { urlFor } from '../../lib/image';
import { getPostUrl } from '../../lib/routes';

const { posts = [] } = Astro.props;

const items = posts.slice(0, 3);

const getImage = (post, width = 640) => {
  if (!post?.featuredImage) return '/placeholder-retro.png';

  return urlFor(post.featuredImage)
    .width(width)
    .quality(74)
    .auto('format')
    .url();
};

const getExcerpt = (post) =>
  post?.excerpt?.replace(/\[…\]/g, '').trim() || '';

const getProductLabel = (post) => {
  const productType = post?.monetization?.productType;

  const map = {
    book: 'Libro',
    hardware: 'Hardware',
    accessory: 'Accessorio',
    software: 'Software',
    gadget: 'Gadget',
    service: 'Servizio',
    other: 'Consigliato'
  };

  if (post?.type === 'hardware') return 'Hardware';

  return map[productType] || 'Consigliato';
};

const getCta = (post) => {
  if (post?.monetization?.isAffiliate) {
    return post.monetization.affiliateLabel || 'Scopri di più';
  }

  return 'Leggi l’articolo';
};
---

<section class="section-box hardware-strip">

  <div class="hardware-strip__header">

    <div>
      <span>Gear, libri & accessori</span>
      <h2>Hardware</h2>
      <p>Console, controller, FPGA, libri, accessori e oggetti retro da tenere d’occhio.</p>
    </div>

    <a href="/hardware/" class="hardware-strip__link">
      Tutto l’hardware
    </a>

  </div>

  {items.length > 0 ? (

    <div class="hardware-strip__grid">

      {items.map((post) => {
        const isAffiliate = post?.monetization?.isAffiliate;
        const productLabel = getProductLabel(post);

        return (
          <a href={getPostUrl(post)} class="hardware-card">

            <div class="hardware-card__image">
              <img
                src={getImage(post, 640)}
                alt={post.featuredImage?.alt || post.title}
                loading="lazy"
              />
            </div>

            <div class="hardware-card__content">
              <span>{productLabel}</span>
              <h3>{post.title}</h3>

              {getExcerpt(post) && (
                <p>{getExcerpt(post)}</p>
              )}

              <small>
                {getCta(post)} →
              </small>

              {isAffiliate && post.monetization?.priceLabel && (
                <em class="hardware-card__price">
                  {post.monetization.priceLabel}
                </em>
              )}
            </div>

          </a>
        );
      })}

    </div>

  ) : (

    <div class="hardware-empty">

      <div class="hardware-empty__content">
        <span>Prossimamente</span>
        <h3>Hardware, accessori e nuove uscite retro</h3>
        <p>
          Qui raccoglieremo console, controller, FPGA, mini sistemi, scaler video,
          libri e prodotti interessanti per chi vive il retro-gaming anche fuori dallo schermo.
        </p>
      </div>

      <div class="hardware-empty__badge">
        <strong>RG</strong>
        <small>GEAR</small>
      </div>

    </div>

  )}

</section>