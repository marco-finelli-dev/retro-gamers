---
import '../../styles/components/specials.css';
import '../../styles/components/meta.css';

const { posts = [] } = Astro.props;

// =========================
// DATA
// =========================

const main = posts[0] || null;
const side = posts.slice(1, 3);

// =========================
// HELPERS
// =========================

const getExcerpt = (post) =>
  post?.excerpt || '';

const getCategory = (post) =>
  post?.categories?.[0] || null;
---

<section class="home-specials">
  <div class="container">

    <div class="section-box">

      <div class="section-header">
        <h2>Speciali</h2>
      </div>

      <div class="specials-grid">

        {/* MAIN */}
        {main && (
          <div class="specials-main card" data-link={`/${main.slug}`}>

            {main.featuredImage?.asset?.url && (
              <img
                src={main.featuredImage.asset.url}
                alt={main.title || ''}
              />
            )}

            <div class="specials-overlay"></div>

            <div class="specials-content">

              {getCategory(main) && (
                <a
                  href={`/categoria/${getCategory(main).slug}`}
                  class="specials-meta"
                >
                  {getCategory(main).name}
                </a>
              )}

              <h3>{main.title}</h3>

              {getExcerpt(main) && (
                <p class="specials-excerpt">
                  {getExcerpt(main)}
                </p>
              )}

            </div>

          </div>
        )}

        {/* SIDE */}
        <div class="specials-side">

          {side.map((post) => {
            const category = getCategory(post);

            return (
              <div class="specials-card card" data-link={`/${post.slug}`}>

                {post.featuredImage?.asset?.url && (
                  <img
                    src={post.featuredImage.asset.url}
                    alt={post.title || ''}
                  />
                )}

                <div class="overlay"></div>

                <div class="specials-content">

                  {category && (
                    <a
                      href={`/categoria/${category.slug}`}
                      class="specials-meta-side"
                    >
                      {category.name}
                    </a>
                  )}

                  <h4>{post.title}</h4>

                </div>

              </div>
            );
          })}

        </div>

      </div>

    </div>

  </div>
</section>