---
import '../../styles/components/specials.css';
import { fetchAPI } from '../../lib/api';
import Meta from '../ui/Meta.astro';
import '../../styles/components/meta.css';

let posts = [];

try {
  const data = await fetchAPI(`
  {
    posts(first: 3, where: { orderby: { field: DATE, order: DESC } }) {
      nodes {
        title
        slug
        excerpt
        datiRecensione {
          riassuntoBreve
        }
        categories {
          nodes { name slug }
        }
        featuredImage {
          node { sourceUrl }
        }
      }
    }
  }
  `);

  posts = data?.posts?.nodes || [];

} catch (e) {
  console.error('Specials fetch error:', e);
}

// =========================
// DATA SAFE
// =========================

const main = posts?.[0] || null;
const side = posts?.slice(1, 3) || [];

// =========================
// HELPERS
// =========================

const getExcerpt = (post) =>
  post?.datiRecensione?.riassuntoBreve ??
  post?.excerpt ??
  '';

const getCategory = (post) =>
  post?.categories?.nodes?.[0] || null;
---

<section class="home-specials">
  <div class="container">

    <div class="section-box">

      <div class="section-header">
        <h2>Speciali</h2>
      </div>

      <div class="specials-grid">

        {/* ================= MAIN ================= */}
        {main && (
          <div class="specials-main card" data-link={`/${main.slug}`}>

            <img
              src={main.featuredImage?.node?.sourceUrl || ''}
              alt={main.title || ''}
            />

            <div class="specials-content">

              {getCategory(main) && (
                <a
                  href={`/${getCategory(main).slug}`}
                  class="specials-meta"
                >
                  {getCategory(main).name}
                </a>
              )}

              <h3>{main.title}</h3>

              {getExcerpt(main) && (
                <p class="specials-excerpt">
                  {getExcerpt(main)}
                </p>
              )}

            </div>

          </div>
        )}

        {/* ================= SIDE ================= */}
        <div class="specials-side">

          {side.map((post) => {
            const category = getCategory(post);

            return (
              <div class="specials-card card" data-link={`/${post.slug}`}>

                <img
                  src={post.featuredImage?.node?.sourceUrl || ''}
                  alt={post.title || ''}
                />

                <div class="overlay"></div>

                <div class="specials-content">

                  {category && (
                    <a
                      href={`/${category.slug}`}
                      class="specials-meta-side"
                    >
                      {category.name}
                    </a>
                  )}

                  <h4>{post.title}</h4>

                </div>

              </div>
            );
          })}

        </div>

      </div>

    </div>

  </div>
</section>