---
import '../../styles/components/memories.css';
import { getPostUrl } from '../../lib/routes';
const { posts = [] } = Astro.props;
---

<section class="home-memories">
  <div class="container">
    <div class="section-box memories">

      <div class="section-header">
        <h2>Memories</h2>
      </div>

      <div class="memories-track">

        {posts.map((post) => (
        <a href={getPostUrl(post)} class="memory-card">

  <div class="memory-inner card">

    <div class="memory-media">
      {post.featuredImage?.asset?.url && (
        <img
          src={post.featuredImage.asset.url}
          alt={post.title || ''}
        />
      )}
    </div>

    <div class="card-content">
      <h3>{post.title}</h3>
    </div>

  </div>

</a>

          </div>
        ))}

      </div>

    </div>
  </div>
</section>