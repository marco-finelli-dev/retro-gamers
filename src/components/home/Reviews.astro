---
import '../../styles/components/reviews.css';
import Meta from '../ui/Meta.astro';
import '../../styles/components/meta.css';
import { urlFor } from '../../lib/image';

const { posts = [] } = Astro.props;

const main = posts[0] || null;
const side = posts.slice(1, 3);

// =========================
// HELPERS
// =========================

const getMeta = (post) => [
  post.platforms?.[0] && {
    label: post.platforms[0].name,
    href: `/piattaforme/${post.platforms[0].slug}`
  },

  post.developers?.[0] && {
    label: post.developers[0].name,
    href: `/sviluppatori/${post.developers[0].slug}`
  },

  post.gameInfo?.releaseYear && {
    label: post.gameInfo.releaseYear,
    href: `/anno/${post.gameInfo.releaseYear}`
  }

].filter(Boolean);

const getScoreClass = (score) => {
  if (score >= 9) return "score-top";
  if (score >= 7) return "score-must";
  return "score-low";
};

const getExcerpt = (post) =>
  post?.excerpt?.replace(/\[…\]/g, '').trim() || '';
---

<section class="home-reviews">
  <div class="container">
    <div class="section-box reviews">

      <div class="section-header">
        <h2>Recensioni</h2>
      </div>

      <div class="reviews-grid">

        {/* MAIN */}
        {main && (
          <div class="review-main card" data-link={`/${main.slug}`}>

            {main.featuredImage && (
              <img
                src={urlFor(main.featuredImage).width(800).url()}
                alt={main.title}
              />
            )}

            <div class={`review-score ${getScoreClass(main.score)}`}>
              <span class="value">{main.score}</span>
            </div>

            <div class="card-content">

              <Meta items={getMeta(main)} />

              <h3 class="card-title-lg">{main.title}</h3>

              {getExcerpt(main) && (
                <p class="card-excerpt">{getExcerpt(main)}</p>
              )}

            </div>
          </div>
        )}

        {/* SIDE */}
        <div class="review-side">
          {side.map(post => (
            <div class="review-card card" data-link={`/${post.slug}`}>

              {post.featuredImage && (
                <img
                  src={urlFor(post.featuredImage).width(400).url()}
                  alt={post.title}
                />
              )}

              <div class={`review-score ${getScoreClass(post.score)}`}>
                <span class="value">{post.score}</span>
              </div>

              <div class="card-content small">

                <Meta items={getMeta(post)} />

                <h4 class="card-title-sm">{post.title}</h4>

                {getExcerpt(post) && (
                  <p class="card-excerpt small">
                    {getExcerpt(post)}
                  </p>
                )}

              </div>

            </div>
          ))}
        </div>

      </div>

    </div>
  </div>
</section>