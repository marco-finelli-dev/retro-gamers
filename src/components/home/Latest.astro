---
import '../../styles/components/latest.css';
import Meta from '../ui/Meta.astro';

const { posts = [] } = Astro.props;

/* ========================
   EXCERPT SYSTEM
======================== */

const stripHTML = (html = '') =>
  html.replace(/<[^>]*>?/gm, '').trim();

const truncate = (text, length = 140) =>
  text.length > length ? text.slice(0, length) + '…' : text;

const getExcerpt = (post) => {
  const clean = stripHTML(post?.excerpt || '');
  if (clean) return truncate(clean, 140);
  return '';
};
---

<section class="latest">
  <div class="container">
    <div class="section-box">

      <div class="section-header">
        <h2>Ultimi articoli</h2>
      </div>

      <div class="latest-grid">

        {posts.map((post) => {
          const category = post.categories?.[0] || null;

          return (
            <article class="latest-item">

              {/* CARD */}
              <div class="card card--media">

                <a href={`/${post.slug}`} class="card-link">
                  {post.featuredImage?.asset?.url && (
                    <img
                      src={post.featuredImage.asset.url}
                      alt={post.title || ''}
                    />
                  )}
                </a>

                {category && (
                  <Meta
                    variant="overlay"
                    items={[
                      {
                        label: category.name,
                        href: `/categoria/${category.slug}`,
                        class: 'meta-badge'
                      }
                    ]}
                  />
                )}

              </div>

              {/* CONTENUTO */}
              <div class="latest-content">

                <h3 class="latest-title">
                  <a href={`/${post.slug}`}>
                    {post.title}
                  </a>
                </h3>

                {getExcerpt(post) && (
                  <p class="latest-excerpt">
                    {getExcerpt(post)}
                  </p>
                )}

              </div>

            </article>
          );
        })}

      </div>

    </div>
  </div>
</section>